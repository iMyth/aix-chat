/**
 * 导出工具列表
 *
 * 在 useAgentChat.ts 里使用：
 *   import { tools } from './tools/xxxTools'
 *
 *   const chat = new Chat({
 *     ...
 *     body: () => ({
 *       agentId: AGENT_ID,
 *       tools: tools.schemas,  // 👈 传给后端
 *     }),
 *     async onToolCall({ toolCall }) {
 *       // 👇 路由到对应的工具执行
 *       const result = await tools.executeTool(toolCall.toolName, toolCall.input)
 *       if (result.pending) {
 *         setPending(toolCall, result)
 *         return
 *       }
 *       chat.addToolOutput(buildToolOutput(toolCall, result))
 *     },
 *   })
 */
export const tools = defineTools([optionSelector, simpleForm])
