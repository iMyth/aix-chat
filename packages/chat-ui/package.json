{
  "name": "aix-chat",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css",
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/styles",
    ".claude"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "type-check": "vue-tsc --noEmit",
    "postinstall": "node scripts/link-skills.cjs"
  },
  "dependencies": {
    "@ai-sdk/vue": "^4.0.28",
    "ai": "^7.0.26",
    "marked": "^18.0.6",
    "pinia": "^4.0.1",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@tsconfig/node24": "^24.0.1",
    "@types/node": "^24.0.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-oxlint": "~0.17.0",
    "eslint-plugin-vue": "~10.2.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.0.1",
    "oxlint": "~0.17.0",
    "sass": "^1.89.2",
    "typescript": "~5.8.0",
    "unplugin-auto-import": "^20.0.0",
    "unplugin-icons": "^22.3.0",
    "unplugin-vue-components": "^28.6.0",
    "vite": "^8.0.0",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.10"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
